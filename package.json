{
  "name": "telegram-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "preview": "vite preview",
    "prepare": "husky",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:db:reset": "supabase db reset",
    "supabase:functions:serve": "supabase functions serve --env-file supabase/.env",
    "supabase:types": "supabase gen types typescript --local > src/lib/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.71.0",
    "supabase": "^2.109.0",
    "typescript": "~6.0.2",
    "ultracite": "^7.8.4",
    "vite": "^8.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css}": [
      "ultracite fix"
    ]
  },
  "packageManager": "pnpm@10.33.2"
}
